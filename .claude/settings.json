{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node agents/doc-updater-hook.js 2>/dev/null || true",
            "async": true,
            "statusMessage": "Checking documentation freshness..."
          }
        ]
      }
    ]
  }
}
